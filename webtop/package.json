{
	"name": "webtop",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=development rollup -c",
		"build:prod": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=production rollup -c",
		"build:webtop": "cross-env BUILD=development TARGETS=webtop rollup -c",
		"build:webtop:prod": "cross-env BUILD=production TARGETS=webtop rollup -c",
		"build:bpm-console": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=development TARGETS=bpm-console rollup -c",
		"build:bpm-console:prod": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=production TARGETS=bpm-console rollup -c",
		"build:bpmn-modeler": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=development TARGETS=bpmn-modeler rollup -c",
		"build:bpmn-modeler:prod": "cross-env NODE_OPTIONS=--max-old-space-size=8192 BUILD=production TARGETS=bpmn-modeler rollup -c",
		"build:content-browser": "cross-env BUILD=development TARGETS=content-browser rollup -c",
		"build:content-browser:prod": "cross-env BUILD=production TARGETS=content-browser rollup -c",
		"build:eip-console": "cross-env BUILD=development TARGETS=eip-console rollup -c",
		"build:eip-console:prod": "cross-env BUILD=production TARGETS=eip-console rollup -c",
		"build:eip-modeler": "cross-env BUILD=development TARGETS=eip-modeler rollup -c",
		"build:eip-modeler:prod": "cross-env BUILD=production TARGETS=eip-modeler rollup -c",
		"build:identity-manager": "cross-env BUILD=development TARGETS=identity-manager rollup -c",
		"build:identity-manager:prod": "cross-env BUILD=production TARGETS=identity-manager rollup -c",
		"build:osgi-console": "cross-env BUILD=development TARGETS=osgi-console rollup -c",
		"build:osgi-console:prod": "cross-env BUILD=production TARGETS=osgi-console rollup -c",
		"build:preferences": "cross-env BUILD=development TARGETS=preferences rollup -c",
		"build:preferences:prod": "cross-env BUILD=production TARGETS=preferences rollup -c",
		"build:schema-manager": "cross-env BUILD=development TARGETS=schema-manager rollup -c",
		"build:schema-manager:prod": "cross-env BUILD=production TARGETS=schema-manager rollup -c",
		"build:tasks": "cross-env BUILD=development TARGETS=tasks rollup -c",
		"build:tasks:prod": "cross-env BUILD=production TARGETS=tasks rollup -c",
		"build:text-editor": "cross-env BUILD=development TARGETS=text-editor rollup -c",
		"build:text-editor:prod": "cross-env BUILD=production TARGETS=text-editor rollup -c",
		"build:text-editor-preview": "cross-env BUILD=development TARGETS=text-editor-preview rollup -c",
		"build:text-editor-preview:prod": "cross-env BUILD=production TARGETS=text-editor-preview rollup -c",
		"prepare": "npm run build",
		"test": "npm run build && node --test"
	},
	"devDependencies": {
		"@codemirror/autocomplete": "^6.20.2",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-java": "^6.0.2",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/lang-php": "^6.0.2",
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/lang-yaml": "^6.1.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/lint": "^6.9.6",
		"@codemirror/search": "^6.7.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@types/marked": "^6.0.0",
		"bootstrap-icons": "^1.13.1",
		"cross-env": "^10.1.0",
		"esbuild": "^0.28.0",
		"inter-ui": "^4.1.1",
		"marked": "^18.0.3",
		"rollup": "^4.60.4",
		"rollup-plugin-copy": "^3.5.0",
