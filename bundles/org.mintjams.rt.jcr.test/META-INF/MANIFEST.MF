Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: JCR Repository Tests
Bundle-SymbolicName: org.mintjams.rt.jcr.test
Bundle-Version: 1.0.0
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-Vendor: MintJams Inc.
Bundle-Activator: org.mintjams.rt.jcr.internal.Activator
Bundle-ClassPath: lib/hamcrest-core-1.3.jar,
 lib/junit-4.13.2.jar,
 .
Require-Bundle: org.mintjams.rt.jcr;bundle-version="1.0.0",
 org.mintjams.jcr;bundle-version="1.0.0"
Import-Package: javax.jcr,
 javax.jcr.security,
 org.mintjams.jcr.util;version="1.0.0",
 org.osgi.framework;version="1.10.0",
 org.osgi.service.component.annotations;version="1.3.0"
Service-Component: OSGI-INF/*.xml
Bundle-ActivationPolicy: lazy
